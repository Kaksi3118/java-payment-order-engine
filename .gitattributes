# Use LF line endings by default across all platforms for consistent diffs.
* text=auto eol=lf

# Windows-specific scripts must keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# Shell scripts must always be LF — critical for the Maven Wrapper (`./mvnw`) on Linux/macOS CI.
*.sh text eol=lf
mvnw text eol=lf

# Binary files — never normalize.
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.keystore binary
*.jks binary